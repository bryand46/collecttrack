# ─────────────────────────────────────────────────────────
# CollectTrack — Environment Variables
# Copy this file to .env.local for local dev
# Paste all values into Vercel Dashboard > Settings > Environment Variables for production
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (neon.tech)
# Local dev:  get from Neon dashboard after creating a project
# Production: same URL (Neon is used for both)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Local dev: http://localhost:3000
# Production: https://your-app-name.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Stripe — from dashboard.stripe.com
# Use sk_test_... keys for dev/staging, sk_live_... for real payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_COLLECTOR="price_..."
STRIPE_PRICE_VAULT="price_..."

# eBay Finding API — from developer.ebay.com (pending approval)
EBAY_APP_ID=""

# Perplexity API — powers AI market value search (perplexity.ai/settings/api)
# Used to find current resale value across eBay, StockX, collector sites, etc.
PERPLEXITY_API_KEY=""
